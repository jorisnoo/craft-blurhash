{% set percentage = eligible > 0 ? ((generated / eligible) * 100)|round : 0 %}

<div class="readable">
    <h2>Blurhash Status</h2>
    <p>{{ generated }} / {{ eligible }} image assets have a blurhash computed ({{ percentage }}%).</p>
</div>

<hr>

<div class="buttons">
    {% if generated < eligible %}
        <form method="post">
            {{ csrfInput() }}
            {{ actionInput('blurhash/blurhash/generate-missing') }}
            {{ redirectInput('utilities/blurhash') }}
            <button type="submit" class="btn submit">Generate Missing</button>
        </form>
    {% endif %}

    <form method="post">
        {{ csrfInput() }}
        {{ actionInput('blurhash/blurhash/regenerate-all') }}
        {{ redirectInput('utilities/blurhash') }}
        <button type="submit" class="btn secondary">Regenerate All</button>
    </form>
</div>

{% if missingAssets | length %}
    <hr>

    <div class="readable">
        <h2>Missing Assets</h2>
        {% set missingCount = eligible - generated %}
        {% if missingCount > missingAssets | length %}
            <p>Showing {{ missingAssets | length }} of {{ missingCount }} assets without a blurhash.</p>
        {% endif %}
    </div>

    <table class="data fullwidth">
        <thead>
            <tr>
                <th></th>
                <th>Filename</th>
                <th>Volume</th>
            </tr>
        </thead>
        <tbody>
            {% for asset in missingAssets %}
                <tr>
                    <td style="width: 34px;">
                        <img src="{{ asset.getThumbUrl(34) }}" width="34" height="34" alt="" style="border-radius: 3px; object-fit: cover;">
                    </td>
                    <td>
                        <a href="{{ asset.cpEditUrl }}">{{ asset.filename }}</a>
                    </td>
                    <td>{{ asset.volume.name }}</td>
                </tr>
            {% endfor %}
        </tbody>
    </table>
{% endif %}
